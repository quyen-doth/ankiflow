rules_version = '2';

// AnkiFlow — Firestore Security Rules (firebase-auth-plan-2026-06-30 の Phase D)。
//
// 最終防御レイヤー: 20+ のクライアントファイルが Firebase client SDK で Firestore を
// 直接読み書きする (middleware + API auth をバイパス)。rules がなければ、誰でも
// console を開いて他ユーザーのデータを直接クエリできてしまう。以下の rules が
// isolation の "source of truth"。
//
// Admin SDK (サーバー API routes) はすべての rule をバイパス — そのためサーバーは
// settings/global への書き込み、__defaults__ の seed などを通常通り実行できる。
// rules はクライアント SDK にのみ適用される。
//
// "Admin" = カスタムクレーム `admin:true` (scripts/set-admin-claim.ts で設定、または
// サインアップ時にメールが ADMIN_EMAIL と一致すれば自動設定)。rules は env を
// 読み取れない → ID token 内のクレームを使う必要がある (API routes でのサーバー側
// メールチェックとは異なる)。
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // 既存のドキュメントが、ログイン中のユーザーに属しているか。
    function owns(rsc) {
      return isSignedIn() && rsc.data.user_id == request.auth.uid;
    }

    // 作成しようとしているドキュメントに、ログイン中のユーザーの user_id が正しく
    // 付与されているか (他人の代わりに作成することを許さない)。
    function creatingOwn() {
      return isSignedIn() && request.resource.data.user_id == request.auth.uid;
    }

    function isProtectedGlobalContentType(id) {
      return id == 'form_language' || id == 'form_it' || id == 'form_general';
    }

    // ─── ユーザーごとのマスターデータ + テンプレート "__defaults__" (admin が /admin 経由で編集) ───
    // decks / categories / card_types / topics: ユーザーは自分のデータを操作; admin は
    // サインアップ時に新規ユーザーがクローンするテンプレート版 (user_id == '__defaults__')
    // も追加・編集できる。
    match /decks/{id} {
      allow read, update, delete: if owns(resource)
        || (isAdmin() && resource.data.user_id == '__defaults__');
      allow create: if creatingOwn()
        || (isAdmin() && request.resource.data.user_id == '__defaults__');
    }
    match /categories/{id} {
      allow read, update, delete: if owns(resource)
        || (isAdmin() && resource.data.user_id == '__defaults__');
      allow create: if creatingOwn()
        || (isAdmin() && request.resource.data.user_id == '__defaults__');
    }
    match /card_types/{id} {
      allow read, update, delete: if owns(resource)
        || (isAdmin() && resource.data.user_id == '__defaults__');
      allow create: if creatingOwn()
        || (isAdmin() && request.resource.data.user_id == '__defaults__');
    }
    match /topics/{id} {
      allow read, update, delete: if owns(resource)
        || (isAdmin() && resource.data.user_id == '__defaults__');
      allow create: if creatingOwn()
        || (isAdmin() && request.resource.data.user_id == '__defaults__');
    }

    // ─── Entries — ユーザーの学習データ、テンプレート版はなく、admin にも特権なし ───
    match /entries/{id} {
      allow read, update, delete: if owns(resource);
      allow create: if creatingOwn();
    }

    // ─── Notification triggers — ユーザーごと (現状 admin のみ使用するが、owner でスコープ) ───
    match /notification_triggers/{id} {
      allow read, update, delete: if owns(resource);
      allow create: if creatingOwn();
    }

    // ─── Review events — SRS revlog (SRS Phase 0)、append-only ───
    // サーバーのみが書き込む (Admin SDK は rules をバイパス): line-webhook + sync-srs。
    // クライアントは自分の履歴のみ読み取り可能 (将来の consumer: 統計/FSRS)。
    match /review_events/{id} {
      allow read: if owns(resource);
      // allow write なし — クライアントは revlog の書き込み/編集/削除ができない
    }

    // ─── User Content Types — workspace ごとの動的フォーム設定 ───
    // list query も `where('user_id', '==', request.auth.uid)` が必須。update では owner を変更不可。
    match /user_content_types/{id} {
      allow read, delete: if owns(resource);
      allow create: if creatingOwn();
      allow update: if owns(resource)
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ─── Content types — 新規ユーザー用のグローバル source snapshot ───
    // 全ユーザーが読み取り可。admin は作成/更新できるが、3 built-in defaults は削除不可。
    match /content_types/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && !isProtectedGlobalContentType(id);
    }

    // ─── Settings — 同じ collection 内の 3 種類の doc ───
    // settings/global: フィーチャーフラグ (secret ではない) — 全ユーザー読み取り、admin 書き込み
    //   (実際はサーバー API/Admin SDK 経由で書き込み; 柔軟性のため admin の client-write も許可)。
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    // settings/default: アプリ所有者の SECRETS (LINE token) — admin のみ読み書き可。
    match /settings/default {
      allow read, write: if isAdmin();
    }
    // settings/{uid}: 各ユーザーの preferences — 本人のみ。
    // (Firebase UID は 28 文字の文字列 — 'global'/'default' と衝突することはない。)
    match /settings/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // デフォルト: 上記で明示的に宣言されていないものはすべて拒否。
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
